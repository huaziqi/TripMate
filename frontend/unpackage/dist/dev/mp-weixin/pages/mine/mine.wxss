
.page.data-v-7c2ebfa5 {
  min-height: 100vh;
  background-color: #f7f8fa;
}

/* 未登录 */
.login-card.data-v-7c2ebfa5 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx 0;
}
.unlogged-tip.data-v-7c2ebfa5 {
  margin-top: 24rpx;
  color: #999;
}
.login-btn.data-v-7c2ebfa5 {
  margin-top: 48rpx;
  width: 480rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 48rpx;
  border: none;
}

/* 头像通用 */
.avatar-circle.data-v-7c2ebfa5 {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-icon.data-v-7c2ebfa5 {
  font-size: 60rpx;
}

/* 已登录 — 个人信息头部 */
.profile-header.data-v-7c2ebfa5 {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
}
.avatar-btn.data-v-7c2ebfa5 {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.avatar-btn.data-v-7c2ebfa5::after {
  border: none;
}
.avatar.data-v-7c2ebfa5 {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
}
.profile-info.data-v-7c2ebfa5 {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}
.nickname-input.data-v-7c2ebfa5 {
  color: #1a1a1a;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.openid-text.data-v-7c2ebfa5 {
  color: #bbb;
}

/* 功能菜单 */
.menu-group.data-v-7c2ebfa5 {
  background-color: #fff;
  border-radius: 16rpx;
  margin: 0 24rpx 24rpx;
  overflow: hidden;
}
.menu-item.data-v-7c2ebfa5 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
}
.menu-label.data-v-7c2ebfa5 {
  color: #1a1a1a;
}
.menu-arrow.data-v-7c2ebfa5 {
  font-size: 40rpx;
  color: #ccc;
}
.divider.data-v-7c2ebfa5 {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 0 32rpx;
}

/* 退出登录 */
.logout-btn.data-v-7c2ebfa5 {
  margin: 0 24rpx;
  background-color: #fff;
  color: #f56c6c;
  border-radius: 16rpx;
  border: none;
}
.logout-btn.data-v-7c2ebfa5::after {
  border: none;
}

/* TabBar 占位 */
.tabbar-placeholder.data-v-7c2ebfa5 {
  height: 140rpx;
}
