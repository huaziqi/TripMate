
.page.data-v-adf21bfd { min-height: 100vh; background: #fff; padding-bottom: 40rpx;
}
.field.data-v-adf21bfd { padding: 24rpx 32rpx;
}
.field-label.data-v-adf21bfd { display: block; font-size: 26rpx; color: #999; margin-bottom: 16rpx;
}
.divider.data-v-adf21bfd { height: 1rpx; background: #f0f0f0;
}
.title-input.data-v-adf21bfd {
  width: 100%; font-size: 34rpx; font-weight: 600;
  color: #1a1a1a; border: none; outline: none; height: 80rpx;
}
.char-count-small.data-v-adf21bfd { display: block; text-align: right; font-size: 22rpx; color: #bbb; margin-top: 4rpx;
}

/* 分类 */
.cat-scroll.data-v-adf21bfd { margin-top: 4rpx;
}
.cat-list.data-v-adf21bfd { display: flex; gap: 16rpx; flex-direction: row; padding: 4rpx 0;
}
.cat-chip.data-v-adf21bfd {
  display: inline-flex; align-items: center;
  padding: 12rpx 28rpx; border-radius: 32rpx;
  border: 1rpx solid #ddd; font-size: 26rpx; color: #666;
  white-space: nowrap;
}
.cat-chip.active.data-v-adf21bfd { border-color: #1677ff; color: #1677ff; background: #e6f0ff;
}

/* 正文 */
.content-textarea.data-v-adf21bfd {
  width: 100%; min-height: 300rpx; font-size: 28rpx; color: #1a1a1a;
  border: none; outline: none; line-height: 1.8; box-sizing: border-box;
}
.char-count.data-v-adf21bfd { display: block; text-align: right; font-size: 22rpx; color: #bbb; margin-top: 8rpx;
}

/* 图片 */
.img-list.data-v-adf21bfd { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 4rpx;
}
.img-item.data-v-adf21bfd { position: relative; width: 200rpx; height: 200rpx; border-radius: 12rpx; overflow: hidden;
}
.img-preview.data-v-adf21bfd { width: 100%; height: 100%;
}
.img-del.data-v-adf21bfd {
  position: absolute; top: 4rpx; right: 4rpx;
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: rgba(0,0,0,0.5); color: #fff;
  display: flex; align-items: center; justify-content: center; font-size: 22rpx;
}
.img-add.data-v-adf21bfd {
  width: 200rpx; height: 200rpx; border-radius: 12rpx;
  border: 2rpx dashed #ccc; display: flex;
  flex-direction: column; align-items: center; justify-content: center; gap: 8rpx;
}
.img-add-icon.data-v-adf21bfd { font-size: 48rpx;
}
.img-add-label.data-v-adf21bfd { font-size: 24rpx; color: #999;
}

/* 发布 */
.submit-wrap.data-v-adf21bfd { padding: 40rpx 32rpx 0;
}
.submit-btn.data-v-adf21bfd {
  width: 100%; height: 88rpx; background: #1677ff; color: #fff;
  border: none; border-radius: 44rpx; font-size: 32rpx;
}
