
.page.data-v-04b95c5c { min-height: 100vh; background: #f7f8fa; display: flex; flex-direction: column;
}

/* 顶部栏（分类 + 搜索） */
.top-bar.data-v-04b95c5c { display: flex; align-items: center; background: #fff; border-bottom: 1rpx solid #eee; flex-shrink: 0;
}
.search-icon.data-v-04b95c5c { padding: 0 24rpx; flex-shrink: 0; display: flex; align-items: center;
}
.search-icon-text.data-v-04b95c5c { font-size: 40rpx;
}

/* 分类条 */
.category-bar.data-v-04b95c5c { flex: 1;
}
.category-list.data-v-04b95c5c { display: flex; flex-direction: row; padding: 0 16rpx; white-space: nowrap;
}
.category-item.data-v-04b95c5c {
  display: inline-block;
  padding: 24rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  white-space: nowrap;
  border-bottom: 4rpx solid transparent;
}
.category-item.active.data-v-04b95c5c { color: #1677ff; border-bottom-color: #1677ff; font-weight: 600;
}

/* 排序 */
.sort-bar.data-v-04b95c5c { display: flex; justify-content: flex-end; padding: 12rpx 24rpx; background: #f7f8fa;
}
.sort-pill.data-v-04b95c5c { display: flex; background: #ebebeb; border-radius: 32rpx; overflow: hidden;
}
.sort-item.data-v-04b95c5c { padding: 10rpx 28rpx; font-size: 24rpx; color: #666;
}
.sort-item.active.data-v-04b95c5c { background: #1677ff; color: #fff; border-radius: 32rpx;
}

/* Feed 滚动区 */
.feed.data-v-04b95c5c { flex: 1;
}

/* 帖子卡片 */
.post-card.data-v-04b95c5c {
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  position: relative;
}
.cover.data-v-04b95c5c { width: 100%; height: 320rpx; display: block;
}
.cover-placeholder.data-v-04b95c5c { width: 100%; height: 180rpx; background: linear-gradient(135deg,#e0f0ff,#b3d9ff);
}
.category-badge.data-v-04b95c5c {
  position: absolute; top: 16rpx; left: 16rpx;
  background: rgba(22,119,255,0.85); color: #fff;
  font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 16rpx;
}
.card-body.data-v-04b95c5c { padding: 20rpx 24rpx 24rpx;
}
.post-title.data-v-04b95c5c { font-size: 30rpx; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 20rpx;
}
.card-meta.data-v-04b95c5c { display: flex; justify-content: space-between; align-items: center;
}
.author-row.data-v-04b95c5c { display: flex; align-items: center; gap: 12rpx;
}
.avatar.data-v-04b95c5c { width: 48rpx; height: 48rpx; border-radius: 50%;
}
.avatar-placeholder.data-v-04b95c5c { width: 48rpx; height: 48rpx; border-radius: 50%; background: #e0e0e0;
}
.author-name.data-v-04b95c5c { font-size: 24rpx; color: #666;
}
.stats-row.data-v-04b95c5c { display: flex; gap: 20rpx;
}
.stat.data-v-04b95c5c { font-size: 24rpx; color: #999;
}

/* 空状态 */
.empty.data-v-04b95c5c { padding: 120rpx 0; text-align: center;
}
.empty-text.data-v-04b95c5c { font-size: 28rpx; color: #bbb;
}

/* 加载提示 */
.loading-tip.data-v-04b95c5c { text-align: center; padding: 24rpx; font-size: 24rpx; color: #bbb;
}

/* 发帖 FAB */
.fab.data-v-04b95c5c {
  position: fixed; right: 40rpx; bottom: 180rpx;
  width: 108rpx; height: 108rpx; border-radius: 54rpx;
  background: linear-gradient(135deg,#1677ff,#4facfe);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(22,119,255,0.4);
  z-index: 100;
}
.fab-icon.data-v-04b95c5c { font-size: 44rpx;
}
.tabbar-placeholder.data-v-04b95c5c { height: 140rpx;
}
