
.page.data-v-b49b36a1 { height: 100vh; display: flex; flex-direction: column;
}

/* ── 任务完成弹窗 ─────────────────────────────────────────────── */
.challenge-popup.data-v-b49b36a1 {
  position: fixed;
  top: 80rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 9999;
  animation: popSlideDown-b49b36a1 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}
@keyframes popSlideDown-b49b36a1 {
from { opacity: 0; transform: translateY(-60rpx) scale(0.9);
}
to   { opacity: 1; transform: translateY(0) scale(1);
}
}
.popup-inner.data-v-b49b36a1 {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.35);
  border: 1rpx solid rgba(255, 107, 53, 0.3);
}
.popup-star.data-v-b49b36a1 {
  font-size: 48rpx;
  flex-shrink: 0;
}
.popup-body.data-v-b49b36a1 {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}
.popup-tag.data-v-b49b36a1 {
  font-size: 22rpx;
  color: #ff9d6b;
  letter-spacing: 1px;
}
.popup-icon.data-v-b49b36a1 {
  font-size: 40rpx;
}
.popup-title.data-v-b49b36a1 {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}
.popup-desc.data-v-b49b36a1 {
  font-size: 22rpx;
  color: #aaa;
}

/* ── 地图 + 画布 ──────────────────────────────────────────────── */
.map-container.data-v-b49b36a1 { flex: 1; position: relative;
}
.map-layer.data-v-b49b36a1 { position: absolute; top: 0; left: 0; width: 100%; height: 100%;
}
.canvas-layer.data-v-b49b36a1 { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: transparent;
}

/* ── 工具栏 ───────────────────────────────────────────────────── */
.toolbar.data-v-b49b36a1 {
  display: flex; align-items: center;
  padding: 12rpx 24rpx; gap: 16rpx;
  background: #fff; border-top: 1rpx solid #eee; border-bottom: 1rpx solid #eee;
}
.tool-btn.data-v-b49b36a1 {
  display: flex; flex-direction: column; align-items: center;
  padding: 10rpx 20rpx; border-radius: 12rpx; background: #f5f6f7;
}
.tool-btn.active.data-v-b49b36a1 { background: #fff3ee;
}
.tool-icon.data-v-b49b36a1 { font-size: 34rpx;
}
.tool-label.data-v-b49b36a1 { font-size: 20rpx; color: #666; margin-top: 4rpx;
}
.tool-hint.data-v-b49b36a1 { flex: 1; text-align: right; font-size: 22rpx; color: #ff6b35;
}

/* ── 底部面板 ──────────────────────────────────────────────────── */
.panel.data-v-b49b36a1 { background: #fff; padding: 20rpx 32rpx;
}
.panel-row.data-v-b49b36a1 {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.panel-label.data-v-b49b36a1 { font-size: 26rpx; color: #888;
}
.panel-value.data-v-b49b36a1 { font-size: 28rpx; color: #222; font-weight: 500;
}

/* ── 挑战任务区 ───────────────────────────────────────────────── */
.challenge-header.data-v-b49b36a1 {
  display: flex;
  align-items: center;
  padding: 16rpx 0 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 12rpx;
}
.challenge-progress-bar.data-v-b49b36a1 {
  flex: 1;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}
.challenge-progress-fill.data-v-b49b36a1 {
  height: 100%;
  background: linear-gradient(90deg, #ff6b35, #f7931e);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}
.challenge-summary.data-v-b49b36a1 {
  font-size: 24rpx;
  color: #555;
  flex-shrink: 0;
}
.challenge-toggle.data-v-b49b36a1 {
  font-size: 22rpx;
  color: #aaa;
  flex-shrink: 0;
}
.challenge-list.data-v-b49b36a1 {
  padding: 8rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.challenge-item.data-v-b49b36a1 {
  display: flex;
  align-items: center;
  padding: 16rpx 8rpx;
  gap: 16rpx;
  border-radius: 12rpx;
  transition: background 0.2s;
}
.challenge-item.done.data-v-b49b36a1 {
  background: #f9fff9;
}
.ci-icon.data-v-b49b36a1 { font-size: 36rpx; flex-shrink: 0;
}
.ci-info.data-v-b49b36a1 { flex: 1;
}
.ci-title.data-v-b49b36a1 {
  font-size: 26rpx;
  font-weight: 600;
  color: #222;
  display: block;
}
.ci-desc.data-v-b49b36a1 {
  font-size: 22rpx;
  color: #888;
  display: block;
  margin-top: 4rpx;
}
.challenge-item.done .ci-title.data-v-b49b36a1 { color: #2e7d32;
}
.ci-check.data-v-b49b36a1 {
  font-size: 32rpx;
  color: #ccc;
  flex-shrink: 0;
}
.challenge-item.done .ci-check.data-v-b49b36a1 { color: #4caf50;
}
.leave-btn.data-v-b49b36a1 {
  margin-top: 20rpx; width: 100%; height: 80rpx; line-height: 80rpx;
  background: #1a1a2e; color: #fff; border-radius: 40rpx; font-size: 28rpx; border: none;
}
