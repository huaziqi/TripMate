
.page.data-v-4c6063a8 { min-height: 100vh; background: #f0f2f5;
}
.header.data-v-4c6063a8 {
  background: #1a1a2e;
  padding: 60rpx 32rpx 40rpx;
  display: flex; flex-direction: column; align-items: center;
}
.header-avatar.data-v-4c6063a8 {
  width: 120rpx; height: 120rpx;
  border-radius: 60rpx; overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-bottom: 16rpx;
  display: flex; align-items: center; justify-content: center;
  background: #333;
}
.avatar.data-v-4c6063a8 { width: 120rpx; height: 120rpx;
}
.avatar-placeholder.data-v-4c6063a8 { width: 120rpx; height: 120rpx; display: flex; align-items: center; justify-content: center; background: #333;
}
.avatar-icon.data-v-4c6063a8 { font-size: 60rpx;
}
.header-name.data-v-4c6063a8 { color: #fff; font-size: 32rpx; font-weight: 600; margin-bottom: 8rpx;
}
.header-count.data-v-4c6063a8 { color: rgba(255,255,255,0.6); font-size: 24rpx;
}

/* Tab 选项栏 */
.tab-bar.data-v-4c6063a8 {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}
.tab-item.data-v-4c6063a8 {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #888;
  position: relative;
}
.tab-item.active.data-v-4c6063a8 {
  color: #1a1a2e;
  font-weight: 600;
}
.tab-item.active.data-v-4c6063a8::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: #1a1a2e;
  border-radius: 2rpx;
}
.tab-count.data-v-4c6063a8 {
  font-size: 22rpx;
  background: #f0f0f0;
  color: #888;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
}
.tab-item.active .tab-count.data-v-4c6063a8 {
  background: #1a1a2e;
  color: #fff;
}
.section.data-v-4c6063a8 { margin: 24rpx 0 0;
}
.badge-grid.data-v-4c6063a8 {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  padding: 16rpx 8rpx;
}
.grid-item.data-v-4c6063a8 {
  width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 28rpx;
}
.badge-name.data-v-4c6063a8 { font-size: 22rpx; color: #333; margin-top: 10rpx; text-align: center; line-height: 1.3;
}
.modal-mask.data-v-4c6063a8 {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.75);
  display: flex; align-items: center; justify-content: center;
  z-index: 1000;
}
.modal.data-v-4c6063a8 {
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 32rpx 40rpx 40rpx;
  width: 580rpx;
  display: flex; flex-direction: column; align-items: center;
}
.modal-rarity-tag.data-v-4c6063a8 { margin-top: 16rpx; padding: 4rpx 20rpx; border-radius: 20rpx; color: #fff; font-size: 22rpx;
}
.modal-name.data-v-4c6063a8 { font-size: 36rpx; font-weight: 700; color: #fff; margin-top: 16rpx;
}
.modal-desc.data-v-4c6063a8 { font-size: 26rpx; color: rgba(255,255,255,0.7); margin-top: 12rpx; text-align: center;
}
.modal-date.data-v-4c6063a8 { font-size: 24rpx; color: rgba(255,255,255,0.5); margin-top: 16rpx;
}
.modal-note.data-v-4c6063a8 { font-size: 22rpx; color: rgba(255,255,255,0.4); margin-top: 8rpx;
}
.modal-close.data-v-4c6063a8 { margin-top: 32rpx; padding: 16rpx 80rpx; background: rgba(255,255,255,0.15); color: #fff; border-radius: 40rpx; font-size: 28rpx;
}
.tabbar-placeholder.data-v-4c6063a8 { height: 140rpx;
}
